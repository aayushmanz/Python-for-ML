   "source": [
    "# Working with missing values -> np.nan\n",
    "import numpy as np\n",
    "\n",
    "a = np.array([1,2,3,4,np.nan]) # nan is for missing value but it is not non\n",
    "\n",
    "print(a)"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[ 1.  2.  3.  4. nan]\n"
     ]
    }
   ],
