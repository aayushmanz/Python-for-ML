    "# anything meaningful ?\n",
    "\n",
    "import time\n",
    "\n",
    "def timer(func):\n",
    "    def wrapper(*args):\n",
    "        start = time.time()\n",
    "        func(*args)\n",
    "        print('time taken by', func.__name__, time.time()-start,'secs')\n",
    "    return wrapper\n",
    "@timer\n",
    "def hello():\n",
    "    print('ayush is a male ')\n",
    "    time.sleep(2)\n",
    "\n",
    "@timer\n",
    "def display():\n",
    "    print('displaying somethings')\n",
    "    time.sleep(5)\n",
    "@timer\n",
    "def square(num):\n",
    "    time.sleep(2)\n",
    "    print(num**2)\n",
    "square(3)\n",
    "display()\n",
    "hello()"
   ],
