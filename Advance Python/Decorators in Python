   },
   "cell_type": "code",
   "source": [
    "# Python are 1 st class function\n",
    "\n",
    "def modify(func, num):\n",
    "    return func(num)\n",
    "def square(num):\n",
    "    return num ** 2\n",
    "\n",
    "modify(square, 9)"
